# Practice Studio static page — cache policy
# index.html must revalidate so deploys show immediately;
# hashed assets are immutable and can cache forever.
<FilesMatch "index\.html$">
  Header set Cache-Control "no-cache, must-revalidate"
</FilesMatch>
<FilesMatch "\.(js|css|jpg|jpeg|png|webp|svg)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
<FilesMatch "\.(mp4|webm|mov)$">
  Header set Cache-Control "public, max-age=2592000"
</FilesMatch>
# serve .jsx as plain text so in-browser Babel can fetch the promo sources
AddType text/plain .jsx
<FilesMatch "\.(jsx|html)$">
  Header set Cache-Control "public, max-age=3600"
</FilesMatch>
